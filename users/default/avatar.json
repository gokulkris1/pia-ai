    "mouth_overlay": true,
    "mouth_min_height_px": 2,
    "mouth_max_height_px": 28,
    "smoothing": 0.75,
    "amplitude_threshold": 8,
    "ripple_rings": 3,
    "ring_color": "rgba(52, 199, 89, 0.35)"
  },

